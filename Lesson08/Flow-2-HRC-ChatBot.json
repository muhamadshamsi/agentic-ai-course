    {
      "parameters": {
        "jsCode": "const contextTexts = items[0].json.result.map(item => {\n  const title = item.payload.metadata.title;\n  const content = item.payload.content;\n  const url = item.payload.metadata.link;\n  return `${title}\\n${content}\\n[Read in knowledge base](${url})`;\n});\n\nconst context = contextTexts.join('\\n---\\n');\n\nreturn [\n  {\n    json: {\n      context: context,\n      question: items[0].json.message,\n    },\n  },\n];"
      },
