    {
      "parameters": {
        "jsCode": "// Get the AI response text\nconst aiResponse = $input.first().json.output;\n\n// Extract the actual URL from the AI response\nfunction extractLinkFromResponse(text) {\n  const linkRegex = /\\[Read in knowledge base\\]\\(([^)]+)\\)/;\n  const match = text.match(linkRegex);\n  return match ? match[1].trim() : \"https://knowledgebase.hrchronicle.com/kb/\";\n}\n\nconst cleanLink = extractLinkFromResponse(aiResponse);\n\n// Format the text for Markdown display\nfunction formatForChat(text) {\n  // Remove the markdown link first (we'll add our version later)\n  text = text.replace(/\\[Read in knowledge base\\]\\([^)]+\\)/, '');\n  \n  // Clean up excessive newlines (2+ newlines → 2 line breaks)\n  text = text.replace(/\\n{3,}/g, '\\n\\n');\n  \n  // Ensure numbered list items are properly formatted with newlines\n  text = text.replace(/(\\d+\\.\\s[^\\n]+)/g, '\\n$1');\n  \n  // Convert any remaining markdown formatting if needed\n  // (bold text already uses ** ** syntax in typical AI responses)\n  \n  // Add the markdown link at the end\n  text += `\\n\\n[Read in knowledge base](${cleanLink})`;\n  \n  // Clean up any extra whitespace\n  text = text.trim();\n  \n  return text;\n}\n\n// Format the AI response\nconst formattedReply = formatForChat(aiResponse);\n\n// Return the formatted message\nreturn [\n  {\n    json: {\n      message: formattedReply,\n      // You can add a format indicator if needed\n      format: 'markdown'\n    }\n  }\n];"
      },
