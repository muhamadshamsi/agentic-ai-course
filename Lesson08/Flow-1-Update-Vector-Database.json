    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const post = item.json;\n  \n  const title = post.title.rendered\n    .replace(/<[^>]*>/g, '')\n    .trim();\n    \n  const content = post.content.rendered\n    .replace(/<[^>]*>/g, '')\n    .replace(/\\s+/g, ' ')\n    .trim();\n  \n  return {\n    json: {\n      pageContent: `${title}\\n\\n${content}`,\n      title: title,\n      link: post.link?.trim(),\n      date: post.date,\n      articleId: post.id\n    }\n  };\n});"
      },
