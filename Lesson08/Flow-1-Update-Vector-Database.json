      "parameters": {
        "jsCode": "const totalPosts = parseInt(\n  $input.first().json.headers['x-wp-total']\n);\nconst totalPages = Math.ceil(totalPosts / 50);\n\nconst pages = [];\nfor (let i = 1; i <= totalPages; i++) {\n  pages.push({ json: { page: i } });\n}\n\nreturn pages;"
      },
